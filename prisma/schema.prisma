generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChannelType {
  EMAIL
  SMS
  PUSH
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SUCCESS
  CANCELED
  ERROR
}

model Notification {
  id          String   @id @default(uuid())
  dateTime    DateTime
  destination String
  message     String   @db.Text()

  channelId Int
  channel   Channel @relation(fields: [channelId], references: [id])

  statusId Int
  status   Status @relation(fields: [statusId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([statusId, dateTime])
}

model Channel {
  id            Int            @id @default(autoincrement())
  description   ChannelType    @unique
  notifications Notification[]

  @@index([description])
}

model Status {
  id            Int                @id @default(autoincrement())
  description   NotificationStatus @unique
  notifications Notification[]

  @@index([description])
}
